# =============================================================
# ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your values
# NEVER commit .env to Git
# =============================================================

# --- Cloudflare (for deployment) ---
CLOUDFLARE_API_TOKEN=           # Cloudflare API Token (deploy permissions)
CLOUDFLARE_ACCOUNT_ID=          # Cloudflare Account ID

# --- Site URL (override for builds) ---
SITE_URL=https://example.com    # Your production domain

# --- Analytics (optional) ---
CLOUDFLARE_ANALYTICS_TOKEN=     # Cloudflare Web Analytics token
GOOGLE_ANALYTICS_ID=            # GA4 measurement ID (optional)

# =============================================================
# WHERE TO FIND THESE VALUES
# =============================================================
#
# CLOUDFLARE_API_TOKEN:
#   Cloudflare Dashboard → My Profile → API Tokens → Create Token
#   Use template: "Edit Cloudflare Workers" or custom with Pages permissions
#
# CLOUDFLARE_ACCOUNT_ID:
#   Cloudflare Dashboard → any domain → Overview → right sidebar
#
# CLOUDFLARE_ANALYTICS_TOKEN:
#   Cloudflare Dashboard → Web Analytics → Add site → copy token
#
# =============================================================
# GITHUB SECRETS (set these in repo Settings → Secrets)
# =============================================================
#
# Required for deployment workflow:
#   CLOUDFLARE_API_TOKEN
#   CLOUDFLARE_ACCOUNT_ID
#
# Optional GitHub Variables (Settings → Variables):
#   CLOUDFLARE_PROJECT_NAME (defaults to 'reusable-web-platform')
#
