---
import { getSiteConfig } from '@/utils/config';

const config = getSiteConfig();
const { gallery } = config;

const categories = ['All', ...new Set(gallery.images.map((img) => img.category))];
---

<section class="section-padding bg-white" id="gallery">
  <div class="container-narrow">
    <!-- Section Header -->
    <div class="section-header">
      <span class="text-primary font-semibold text-sm uppercase tracking-wider">Portfolio</span>
      <h2 class="section-title mt-2">{gallery.title}</h2>
      <p class="section-subtitle">{gallery.subtitle}</p>
    </div>

    <!-- Category Filters -->
    <div class="flex flex-wrap justify-center gap-2 mb-10" id="gallery-filters">
      {
        categories.map((cat, i) => (
          <button
            class:list={[
              'px-4 py-2 rounded-full text-sm font-medium transition-all duration-200 gallery-filter-btn',
              i === 0
                ? 'bg-primary text-white'
                : 'bg-surface text-neutral/70 hover:bg-primary/10 hover:text-primary',
            ]}
            data-category={cat}
          >
            {cat}
          </button>
        ))
      }
    </div>

    <!-- Gallery Grid -->
    <div class="grid grid-cols-2 md:grid-cols-3 gap-4" id="gallery-grid">
      {
        gallery.images.map((image) => (
          <div
            class="gallery-item group relative aspect-[3/2] overflow-hidden rounded-theme cursor-pointer"
            data-category={image.category}
          >
            <img
              src={image.src}
              alt={image.alt}
              class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-neutral/0 group-hover:bg-neutral/50 transition-all duration-300 flex items-center justify-center">
              <div class="opacity-0 group-hover:opacity-100 transition-opacity duration-300 text-center">
                <svg
                  class="w-8 h-8 text-white mx-auto mb-2"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7"
                  />
                </svg>
                <p class="text-white text-sm font-medium">{image.alt}</p>
                <span class="text-white/70 text-xs">{image.category}</span>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<!-- Lightbox -->
<div
  class="fixed inset-0 z-[60] bg-black/90 hidden items-center justify-center p-4"
  id="lightbox"
  role="dialog"
  aria-label="Image viewer"
>
  <button
    class="absolute top-4 right-4 text-white/80 hover:text-white p-2 z-10"
    id="lightbox-close"
    aria-label="Close image viewer"
  >
    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"
      ></path>
    </svg>
  </button>
  <img src="" alt="" class="max-w-full max-h-[85vh] object-contain rounded-lg" id="lightbox-img" />
  <p
    class="absolute bottom-6 left-1/2 -translate-x-1/2 text-white/80 text-sm"
    id="lightbox-caption"
  >
  </p>
</div>

<script>
  // Gallery filtering
  const filterBtns = document.querySelectorAll('.gallery-filter-btn');
  const galleryItems = document.querySelectorAll('.gallery-item');

  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const category = btn.getAttribute('data-category');

      // Update active button
      filterBtns.forEach((b) => {
        b.classList.remove('bg-primary', 'text-white');
        b.classList.add('bg-surface', 'text-neutral/70');
      });
      btn.classList.add('bg-primary', 'text-white');
      btn.classList.remove('bg-surface', 'text-neutral/70');

      // Filter items
      galleryItems.forEach((item) => {
        const el = item as HTMLElement;
        if (category === 'All' || item.getAttribute('data-category') === category) {
          el.style.display = '';
        } else {
          el.style.display = 'none';
        }
      });
    });
  });

  // Lightbox
  const lightbox = document.getElementById('lightbox');
  const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
  const lightboxCaption = document.getElementById('lightbox-caption');
  const lightboxClose = document.getElementById('lightbox-close');

  galleryItems.forEach((item) => {
    item.addEventListener('click', () => {
      const img = item.querySelector('img');
      if (img && lightboxImg && lightbox && lightboxCaption) {
        lightboxImg.src = img.src;
        lightboxImg.alt = img.alt;
        lightboxCaption.textContent = img.alt;
        lightbox.classList.remove('hidden');
        lightbox.classList.add('flex');
        document.body.style.overflow = 'hidden';
      }
    });
  });

  function closeLightbox() {
    if (lightbox) {
      lightbox.classList.add('hidden');
      lightbox.classList.remove('flex');
      document.body.style.overflow = '';
    }
  }

  lightboxClose?.addEventListener('click', closeLightbox);
  lightbox?.addEventListener('click', (e) => {
    if (e.target === lightbox) closeLightbox();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeLightbox();
  });
</script>
