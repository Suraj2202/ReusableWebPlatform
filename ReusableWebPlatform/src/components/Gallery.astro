---
import { getSiteConfig } from '@/utils/config';
import OptimizedImage from '@/components/OptimizedImage.astro';

const config = getSiteConfig();
const { gallery } = config;

const categories = ['All', ...new Set(gallery.images.map((img) => img.category))];
const INITIAL_SHOW = 8;
---

<section class="section-padding bg-white" id="gallery">
  <div class="container-narrow">
    <!-- Section Header -->
    <div class="section-header" data-animate="fade-up">
      <span class="text-primary font-semibold text-sm uppercase tracking-wider">Portfolio</span>
      <h2 class="section-title mt-2">{gallery.title}</h2>
      <p class="section-subtitle">{gallery.subtitle}</p>
    </div>

    <!-- Category Filters -->
    <div
      class="flex flex-wrap justify-center gap-2 mb-10"
      id="gallery-filters"
      data-animate="fade-up"
      data-delay="200"
    >
      {
        categories.map((cat, i) => (
          <button
            class:list={[
              'px-4 py-2 rounded-full text-sm font-medium transition-all duration-200 gallery-filter-btn',
              i === 0
                ? 'bg-primary text-white shadow-md'
                : 'bg-surface text-neutral/70 hover:bg-primary/10 hover:text-primary',
            ]}
            data-category={cat}
          >
            {cat}
          </button>
        ))
      }
    </div>

    <!-- Gallery Grid -->
    <div
      class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3 md:gap-4"
      id="gallery-grid"
      data-stagger
    >
      {
        gallery.images.map((image, idx) => (
          <div
            class:list={[
              'gallery-item group relative aspect-[3/2] overflow-hidden rounded-theme',
              idx >= INITIAL_SHOW ? 'hidden' : '',
            ]}
            data-category={image.category}
            data-index={idx}
            data-animate="zoom-in"
          >
            <OptimizedImage
              src={image.src}
              alt={image.alt}
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110 img-lazy"
              loading="lazy"
              decoding="async"
              responsive={true}
              width={480}
              height={320}
            />
            <div class="absolute inset-0 bg-gradient-to-t from-neutral/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-3">
              <p class="text-white text-xs font-medium line-clamp-1">{image.alt}</p>
            </div>
          </div>
        ))
      }
    </div>

    <!-- Show More Button -->
    {
      gallery.images.length > INITIAL_SHOW && (
        <div class="text-center mt-8" id="gallery-show-more">
          <button
            class="inline-flex items-center gap-2 px-6 py-3 bg-primary/10 text-primary font-medium rounded-full hover:bg-primary hover:text-white transition-all duration-300"
            id="gallery-expand-btn"
          >
            <span>Show all {gallery.images.length} photos</span>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M19 9l-7 7-7-7"
              />
            </svg>
          </button>
        </div>
      )
    }
  </div>
</section>

<script>
  const galleryItems = document.querySelectorAll('.gallery-item') as NodeListOf<HTMLElement>;
  const filterBtns = document.querySelectorAll('.gallery-filter-btn');
  const expandBtn = document.getElementById('gallery-expand-btn');
  const showMoreContainer = document.getElementById('gallery-show-more');

  let activeCategory = 'All';
  let isExpanded = false;
  const INITIAL_SHOW = 8;

  function getVisibleItems(): HTMLElement[] {
    return Array.from(galleryItems).filter((item) => {
      return activeCategory === 'All' || item.dataset.category === activeCategory;
    });
  }

  function applyFilter() {
    const visible = getVisibleItems();
    const limit = isExpanded ? Infinity : INITIAL_SHOW;

    galleryItems.forEach((item) => {
      const matchesCategory = activeCategory === 'All' || item.dataset.category === activeCategory;
      const idx = visible.indexOf(item);
      if (matchesCategory && idx < limit) {
        item.classList.remove('hidden');
      } else {
        item.classList.add('hidden');
      }
    });

    // Update show-more button
    if (showMoreContainer) {
      if (visible.length > INITIAL_SHOW && !isExpanded) {
        showMoreContainer.classList.remove('hidden');
        if (expandBtn) {
          const span = expandBtn.querySelector('span');
          if (span) span.textContent = `Show all ${visible.length} photos`;
        }
      } else {
        showMoreContainer.classList.add('hidden');
      }
    }
  }

  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      activeCategory = btn.getAttribute('data-category') || 'All';
      isExpanded = false;

      filterBtns.forEach((b) => {
        b.classList.remove('bg-primary', 'text-white', 'shadow-md');
        b.classList.add('bg-surface', 'text-neutral/70');
      });
      btn.classList.add('bg-primary', 'text-white', 'shadow-md');
      btn.classList.remove('bg-surface', 'text-neutral/70');

      applyFilter();
    });
  });

  expandBtn?.addEventListener('click', () => {
    isExpanded = true;
    applyFilter();
  });

  applyFilter();
</script>
