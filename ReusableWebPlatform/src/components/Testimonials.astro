---
import { getSiteConfig } from '@/utils/config';

const config = getSiteConfig();
const { testimonials } = config;
---

<section class="section-padding bg-surface" id="testimonials">
  <div class="container-narrow">
    <!-- Section Header -->
    <div class="section-header" data-animate="fade-up">
      <span class="text-primary font-semibold text-sm uppercase tracking-wider">Testimonials</span>
      <h2 class="section-title mt-2">{testimonials.title}</h2>
      <p class="section-subtitle">{testimonials.subtitle}</p>
    </div>

    <!-- Testimonials Grid -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8" data-stagger>
      {
        testimonials.items.map((item) => (
          <div
            class="bg-white rounded-theme p-8 shadow-sm hover:shadow-lg transition-shadow duration-300 relative card-hover"
            data-animate="fade-up"
          >
            <svg
              class="w-10 h-10 text-primary/15 absolute top-6 right-6"
              fill="currentColor"
              viewBox="0 0 24 24"
            >
              <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151C7.546 6.068 5.983 8.789 5.983 11H10v10H0z" />
            </svg>

            <div class="flex gap-1 mb-4">
              {Array.from({ length: 5 }).map((_, i) => (
                <svg
                  class:list={['w-5 h-5', i < item.rating ? 'text-accent' : 'text-neutral/20']}
                  fill="currentColor"
                  viewBox="0 0 20 20"
                >
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>

            <blockquote class="text-neutral/70 leading-relaxed mb-6 italic">
              "{item.quote}"
            </blockquote>

            <div class="flex items-center gap-3">
              {item.avatar ? (
                <img
                  src={item.avatar}
                  alt={item.name}
                  class="w-12 h-12 rounded-full object-cover"
                  loading="lazy"
                />
              ) : (
                <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center">
                  <span class="text-primary font-bold text-lg">{item.name.charAt(0)}</span>
                </div>
              )}
              <div>
                <div class="font-semibold text-neutral">{item.name}</div>
                <div class="text-sm text-neutral/50">{item.role}</div>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
