---
import { getSiteConfig } from '@/utils/config';
import OptimizedImage from '@/components/OptimizedImage.astro';

const config = getSiteConfig();
const { about } = config;
---

<section class="section-padding bg-white" id="about">
  <div class="container-narrow">
    <div class="grid md:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Image -->
      <div class="order-2 md:order-1" data-animate="fade-right">
        {
          about.image && (
            <div class="relative">
              <OptimizedImage
                src={about.image}
                alt={about.title}
                class="rounded-theme shadow-lg w-full object-cover aspect-[4/3] img-lazy"
                loading="lazy"
                decoding="async"
                width={640}
                height={480}
              />
            </div>
          )
        }
      </div>

      <!-- Content -->
      <div class="order-1 md:order-2" data-animate="fade-left">
        <span class="text-primary font-semibold text-sm uppercase tracking-wider">About Us</span>
        <h2 class="text-3xl md:text-4xl font-bold text-neutral mt-2 mb-6">
          {about.title}
        </h2>
        <p class="text-neutral/70 leading-relaxed text-lg mb-8">
          {about.description}
        </p>

        <!-- Stats -->
        {
          about.stats && about.stats.length > 0 && (
            <div class="grid grid-cols-2 gap-6" data-stagger>
              {about.stats.map((stat) => (
                <div
                  class="text-center p-4 bg-surface rounded-theme card-hover"
                  data-animate="fade-up"
                >
                  <div class="text-3xl font-bold text-primary" data-count={stat.value}>
                    {stat.value}
                  </div>
                  <div class="text-sm text-neutral/60 mt-1">{stat.label}</div>
                </div>
              ))}
            </div>
          )
        }
      </div>
    </div>
  </div>
</section>
