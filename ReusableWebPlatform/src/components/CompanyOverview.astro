---
import { siteConfig } from '@/utils/whatsapp';

const overview = siteConfig.overview;
const { eyebrow, heading, body, stats = [] } = overview;
---

<section
  id="overview"
  class="bg-surface py-16 sm:py-20 lg:py-24"
  aria-labelledby="overview-heading"
>
  <div class="mx-auto grid max-w-6xl gap-10 px-6 lg:grid-cols-2 lg:items-center lg:gap-16">
    <!-- Copy -->
    <div>
      {
        eyebrow && (
          <p class="font-body text-sm font-semibold uppercase tracking-[0.18em] text-accent">
            {eyebrow}
          </p>
        )
      }
      <h2 id="overview-heading" class="mt-3 font-heading text-3xl text-primary sm:text-4xl">
        {heading}
      </h2>
      <div class="mt-6 space-y-4">
        {
          body.map((para: string) => (
            <p class="font-body text-lg leading-relaxed text-neutral/80">{para}</p>
          ))
        }
      </div>
    </div>

    <!-- Stats -->
    {
      stats.length > 0 && (
        <dl class="grid grid-cols-3 gap-4 sm:gap-6">
          {stats.map((stat: { value: string; label: string }) => (
            <div class="rounded-theme border border-neutral/10 bg-white p-5 text-center shadow-sm">
              <dt class="sr-only">{stat.label}</dt>
              <dd class="font-heading text-3xl font-semibold text-primary sm:text-4xl">
                {stat.value}
              </dd>
              <p class="mt-2 font-body text-xs font-medium uppercase tracking-wide text-neutral/60 sm:text-sm">
                {stat.label}
              </p>
            </div>
          ))}
        </dl>
      )
    }
  </div>
</section>
