---
import { getCollection } from 'astro:content';
import { siteConfig, whatsappHref } from '@/utils/whatsapp';

const { name, tagline } = siteConfig.site;
const igHandle = siteConfig.social.instagram;
const igUrl = `https://instagram.com/${igHandle}`;
const email = siteConfig.contact.email;
const enquireHref = whatsappHref(`Hi ${name}, I'd like help planning a trip.`);
const year = new Date().getFullYear();

const categories = (await getCollection('categories')).sort((a, b) => a.data.order - b.data.order);

const exploreLinks = categories.map((c) => ({
  label: c.data.title,
  href: `/explore/${c.data.slug}`,
}));

const planLinks = [
  { label: 'Family Trips', href: '/family' },
  { label: 'School Trips', href: '/school' },
  { label: 'Corporate Trips', href: '/corporate' },
];

const companyLinks = [
  { label: 'About Us', href: '/about' },
  { label: 'Contact', href: '/contact' },
];
---

<footer class="border-t border-neutral/10 bg-secondary text-surface">
  <!-- Mobile layout (< sm): centered, compact -->
  <div class="flex flex-col items-center px-6 py-10 sm:hidden">
    <!-- Brand -->
    <h2 class="font-heading text-2xl text-surface">{name}</h2>
    <p class="mt-2 max-w-xs text-center font-body text-sm text-surface/70">{tagline}</p>
    <a
      href={enquireHref}
      target="_blank"
      rel="noopener noreferrer"
      class="mt-5 inline-flex min-h-[44px] items-center rounded-theme bg-accent px-6 py-2.5 font-body text-sm font-semibold text-neutral transition hover:bg-surface hover:text-primary"
    >
      Plan on WhatsApp
    </a>

    <!-- Nav links in 3-col compact grid -->
    <div class="mt-8 grid w-full grid-cols-3 gap-y-6 text-center">
      <nav aria-label="Explore">
        <h3 class="font-body text-xs font-semibold uppercase tracking-wide text-accent">Explore</h3>
        <ul class="mt-2.5 space-y-1.5">
          {
            exploreLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="font-body text-sm text-surface/80 transition-colors hover:text-surface"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
      <nav aria-label="Plan with us">
        <h3 class="font-body text-xs font-semibold uppercase tracking-wide text-accent">
          Plan With Us
        </h3>
        <ul class="mt-2.5 space-y-1.5">
          {
            planLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="font-body text-sm text-surface/80 transition-colors hover:text-surface"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
      <nav aria-label="Company">
        <h3 class="font-body text-xs font-semibold uppercase tracking-wide text-accent">Company</h3>
        <ul class="mt-2.5 space-y-1.5">
          {
            companyLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="font-body text-sm text-surface/80 transition-colors hover:text-surface"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </div>

    <!-- Social row -->
    <div class="mt-8 flex items-center gap-5">
      <a
        href={`mailto:${email}`}
        class="font-body text-xs text-surface/70 transition-colors hover:text-surface"
      >
        {email}
      </a>
      <a
        href={igUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1.5 font-body text-xs text-surface/70 transition-colors hover:text-surface"
        aria-label={`Follow on Instagram @${igHandle}`}
      >
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          aria-hidden="true"
        >
          <rect x="2" y="2" width="20" height="20" rx="5"></rect>
          <circle cx="12" cy="12" r="4"></circle>
          <line x1="17.5" y1="6.5" x2="17.5" y2="6.5"></line>
        </svg>
        @{igHandle}
      </a>
    </div>
  </div>

  <!-- Tablet / Desktop layout (sm+): original 4-col grid -->
  <div class="mx-auto hidden max-w-7xl gap-10 px-6 py-12 sm:grid sm:grid-cols-2 lg:grid-cols-4">
    <!-- Brand -->
    <div>
      <h2 class="font-heading text-2xl text-surface">{name}</h2>
      <p class="mt-3 max-w-xs font-body text-sm text-surface/70">{tagline}</p>
      <a
        href={enquireHref}
        target="_blank"
        rel="noopener noreferrer"
        class="mt-5 inline-flex min-h-[44px] items-center rounded-theme bg-accent px-5 py-2 font-body text-sm font-semibold text-neutral transition hover:bg-surface hover:text-primary"
      >
        Plan on WhatsApp
      </a>
    </div>

    <!-- Explore -->
    <nav aria-label="Explore">
      <h3 class="font-body text-sm font-semibold uppercase tracking-wide text-accent">Explore</h3>
      <ul class="mt-4 space-y-2">
        {
          exploreLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="font-body text-sm text-surface/80 transition-colors hover:text-surface"
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <!-- Plan With Us -->
    <nav aria-label="Plan with us">
      <h3 class="font-body text-sm font-semibold uppercase tracking-wide text-accent">
        Plan With Us
      </h3>
      <ul class="mt-4 space-y-2">
        {
          planLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="font-body text-sm text-surface/80 transition-colors hover:text-surface"
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <!-- Company + social -->
    <nav aria-label="Company">
      <h3 class="font-body text-sm font-semibold uppercase tracking-wide text-accent">Company</h3>
      <ul class="mt-4 space-y-2">
        {
          companyLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="font-body text-sm text-surface/80 transition-colors hover:text-surface"
              >
                {link.label}
              </a>
            </li>
          ))
        }
        <li>
          <a
            href={`mailto:${email}`}
            class="font-body text-sm text-surface/80 transition-colors hover:text-surface"
          >
            {email}
          </a>
        </li>
        <li>
          <a
            href={igUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 font-body text-sm text-surface/80 transition-colors hover:text-surface"
          >
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              aria-hidden="true"
            >
              <rect x="2" y="2" width="20" height="20" rx="5"></rect>
              <circle cx="12" cy="12" r="4"></circle>
              <line x1="17.5" y1="6.5" x2="17.5" y2="6.5"></line>
            </svg>
            @{igHandle}
          </a>
        </li>
      </ul>
    </nav>
  </div>

  <div class="border-t border-surface/10">
    <div class="mx-auto max-w-7xl px-6 py-5 text-center font-body text-xs text-surface/60">
      © {year}
      {name}. All rights reserved.
    </div>
  </div>
</footer>
