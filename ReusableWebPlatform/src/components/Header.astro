---
import { getCollection } from 'astro:content';
import { siteConfig, whatsappHref } from '@/utils/whatsapp';

const { name } = siteConfig.site;

const categories = (await getCollection('categories')).sort((a, b) => a.data.order - b.data.order);

const navLinks = [
  { label: 'Home', href: '/' },
  ...categories.map((c) => ({ label: c.data.title, href: `/explore/${c.data.slug}` })),
  { label: 'Family', href: '/family' },
  { label: 'School', href: '/school' },
  { label: 'Corporate', href: '/corporate' },
  { label: 'About', href: '/about' },
  { label: 'Contact', href: '/contact' },
];

// Grouped links for mobile drawer
const drawerSections = [
  {
    heading: 'Explore',
    links: categories.map((c) => ({ label: c.data.title, href: `/explore/${c.data.slug}` })),
  },
  {
    heading: 'Plan With Us',
    links: [
      { label: 'Family Trips', href: '/family' },
      { label: 'School Trips', href: '/school' },
      { label: 'Corporate Trips', href: '/corporate' },
    ],
  },
  {
    heading: 'Company',
    links: [
      { label: 'About Us', href: '/about' },
      { label: 'Contact', href: '/contact' },
    ],
  },
];

const enquireHref = whatsappHref(`Hi ${name}, I'd like help planning a trip.`);
---

<div id="header-root">
<header
  id="site-header"
  class="sticky top-0 z-50 w-full border-b border-neutral/10 bg-surface/90 backdrop-blur transition-shadow duration-200"
>
  <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-4 sm:px-6">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2" aria-label={`${name} home`}>
      <img
        src="/assets/brand/logo.svg"
        alt={`${name} logo`}
        width="160"
        height="40"
        class="h-9 w-auto"
      />
    </a>

    <!-- Desktop nav -->
    <nav class="hidden items-center gap-7 md:flex" aria-label="Primary">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class="font-body text-sm font-medium text-neutral/80 transition-colors hover:text-primary"
          >
            {link.label}
          </a>
        ))
      }
      <a
        href={enquireHref}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex min-h-[44px] items-center rounded-theme bg-accent px-5 py-2 font-body text-sm font-semibold text-neutral shadow-sm transition hover:bg-primary hover:text-surface"
      >
        Enquire
      </a>
    </nav>

    <!-- Mobile hamburger -->
    <button
      id="menu-open"
      type="button"
      class="inline-flex h-11 w-11 items-center justify-center rounded-theme text-neutral md:hidden"
      aria-label="Open menu"
      aria-controls="mobile-drawer"
      aria-expanded="false"
    >
      <svg
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        aria-hidden="true"
      >
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </button>
  </div>
</header>

<!-- Mobile drawer -->
<div
  id="mobile-drawer"
  class="fixed inset-0 z-[60] hidden md:hidden"
  role="dialog"
  aria-modal="true"
  aria-label="Menu"
>
  <!-- Backdrop -->
  <div
    id="drawer-backdrop"
    class="drawer-backdrop absolute inset-0 bg-neutral/50 opacity-0 transition-opacity duration-200"
  >
  </div>

  <!-- Panel -->
  <div
    id="drawer-panel"
    class="drawer-panel absolute right-0 top-0 flex h-full w-[82%] max-w-sm translate-x-full flex-col bg-surface shadow-xl transition-transform duration-300"
    style="padding-top: env(safe-area-inset-top); padding-bottom: env(safe-area-inset-bottom);"
  >
    <div class="flex h-16 items-center justify-between border-b border-neutral/10 px-5">
      <span class="font-heading text-lg text-primary">{name}</span>
      <button
        id="menu-close"
        type="button"
        class="inline-flex h-11 w-11 items-center justify-center rounded-theme text-neutral"
        aria-label="Close menu"
      >
        <svg
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          aria-hidden="true"
        >
          <line x1="6" y1="6" x2="18" y2="18"></line>
          <line x1="18" y1="6" x2="6" y2="18"></line>
        </svg>
      </button>
    </div>

    <nav class="flex flex-1 flex-col overflow-y-auto px-3 py-4" aria-label="Mobile">
      <!-- Home link -->
      <a
        href="/"
        class="drawer-link rounded-theme px-4 py-3 font-body text-base font-semibold text-primary"
      >
        Home
      </a>

      {
        drawerSections.map((section) => (
          <div class="mt-3">
            <span class="px-4 font-body text-xs font-semibold uppercase tracking-wide text-neutral/50">
              {section.heading}
            </span>
            <div class="mt-1 flex flex-col gap-0.5">
              {section.links.map((link) => (
                <a
                  href={link.href}
                  class="drawer-link rounded-theme px-4 py-2.5 font-body text-sm font-medium text-neutral transition-colors hover:bg-primary/5 hover:text-primary"
                >
                  {link.label}
                </a>
              ))}
            </div>
          </div>
        ))
      }
    </nav>

    <div class="border-t border-neutral/10 p-4">
      <a
        href={enquireHref}
        target="_blank"
        rel="noopener noreferrer"
        class="drawer-link flex min-h-[48px] items-center justify-center rounded-theme bg-accent px-5 font-body font-semibold text-neutral shadow-sm transition hover:bg-primary hover:text-surface"
      >
        Enquire on WhatsApp
      </a>
    </div>
  </div>
</div>
</div>

<script>
  /**
   * Mobile drawer navigation — resilient to View Transition DOM swaps.
   * All element refs are queried fresh on each interaction (never cached).
   * Event delegation on document ensures listeners survive element replacement.
   */

  let lastFocused: HTMLElement | null = null;

  function getEls() {
    return {
      header: document.getElementById('site-header'),
      drawer: document.getElementById('mobile-drawer'),
      backdrop: document.getElementById('drawer-backdrop'),
      panel: document.getElementById('drawer-panel'),
      openBtn: document.getElementById('menu-open'),
      closeBtn: document.getElementById('menu-close'),
    };
  }

  function isDrawerOpen() {
    const { drawer } = getEls();
    return drawer ? !drawer.classList.contains('hidden') : false;
  }

  function openDrawer() {
    const { drawer, backdrop, panel, openBtn, closeBtn } = getEls();
    if (!drawer || !backdrop || !panel) return;
    lastFocused = document.activeElement as HTMLElement;
    drawer.classList.remove('hidden');
    requestAnimationFrame(() => {
      backdrop.style.opacity = '1';
      panel.classList.remove('translate-x-full');
    });
    openBtn?.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
    closeBtn?.focus();
  }

  function closeDrawer() {
    const { drawer, backdrop, panel, openBtn } = getEls();
    if (!drawer || !backdrop || !panel) return;
    if (drawer.classList.contains('hidden')) return; // already closed
    backdrop.style.opacity = '0';
    panel.classList.add('translate-x-full');
    openBtn?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
    const finish = () => {
      drawer.classList.add('hidden');
      panel.removeEventListener('transitionend', finish);
      clearTimeout(safetyTimer);
    };
    const safetyTimer = setTimeout(finish, 350);
    panel.addEventListener('transitionend', finish, { once: true });
    lastFocused?.focus();
  }

  // --- Event delegation (survives DOM replacement) ---
  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    if (target.closest('#menu-open')) {
      openDrawer();
      return;
    }
    if (target.closest('#menu-close') || target.closest('#drawer-backdrop')) {
      closeDrawer();
      return;
    }
    if (target.closest('.drawer-link') && isDrawerOpen()) {
      closeDrawer();
    }
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && isDrawerOpen()) {
      closeDrawer();
    }
    if (e.key === 'Tab' && isDrawerOpen()) {
      const { panel } = getEls();
      if (!panel) return;
      const focusable = panel.querySelectorAll<HTMLElement>('a[href], button:not([disabled])');
      if (focusable.length === 0) return;
      const first = focusable[0];
      const last = focusable[focusable.length - 1];
      if (e.shiftKey && document.activeElement === first) {
        e.preventDefault();
        last.focus();
      } else if (!e.shiftKey && document.activeElement === last) {
        e.preventDefault();
        first.focus();
      }
    }
  });

  // Scroll shadow
  let ticking = false;
  window.addEventListener('scroll', () => {
    if (!ticking) {
      requestAnimationFrame(() => {
        const { header } = getEls();
        if (header) {
          header.classList.toggle('shadow-md', window.scrollY > 8);
        }
        ticking = false;
      });
      ticking = true;
    }
  });

  // Safety reset after View Transition swap
  document.addEventListener('astro:after-swap', () => {
    const { drawer, backdrop, panel, openBtn } = getEls();
    if (drawer && !drawer.classList.contains('hidden')) {
      drawer.classList.add('hidden');
      if (backdrop) backdrop.style.opacity = '0';
      panel?.classList.add('translate-x-full');
      openBtn?.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    }
  });
</script>
