---
import { siteConfig } from '@/utils/whatsapp';
import social from '../../content/data/social.json';

// Static snapshot — the live site never calls an API (see docs/rules/04-social-sync.md).
const google = social.google;
const instagram = social.instagram;

const igHandle = instagram?.handle ?? siteConfig.social.instagram;
const igUrl = instagram?.profileUrl ?? `https://instagram.com/${igHandle}`;

// Compact follower count: 18400 -> "18.4K"
function compact(n?: number): string {
  if (typeof n !== 'number') return '';
  if (n >= 1000) {
    const k = n / 1000;
    return `${k % 1 === 0 ? k.toFixed(0) : k.toFixed(1)}K`;
  }
  return String(n);
}

const rating = google?.rating;
const filledStars = rating ? Math.round(rating) : 0;
const reviewCount = google?.reviewCount;
const reviewsUrl = google?.reviewsUrl;
const followers = instagram?.followers;
---

<section class="border-y border-neutral/10 bg-white" aria-label="Social proof">
  <div class="mx-auto flex max-w-3xl items-center justify-center gap-4 px-4 py-3 sm:gap-8 sm:px-6">
    <!-- Google reviews -->
    {
      rating && (
        <a
          href={reviewsUrl ?? '#'}
          target="_blank"
          rel="noopener noreferrer"
          class="group flex items-center gap-2.5 sm:gap-3"
          aria-label={`Google rating ${rating} out of 5${reviewCount ? `, ${reviewCount}+ reviews` : ''}`}
        >
          <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-neutral/5 transition group-hover:bg-neutral/10">
            <svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true">
              <path
                fill="#4285F4"
                d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.27-4.74 3.27-8.1z"
              />
              <path
                fill="#34A853"
                d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.99.66-2.26 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84A11 11 0 0 0 12 23z"
              />
              <path
                fill="#FBBC05"
                d="M5.84 14.1a6.6 6.6 0 0 1 0-4.2V7.06H2.18a11 11 0 0 0 0 9.88l3.66-2.84z"
              />
              <path
                fill="#EA4335"
                d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.06l3.66 2.84C6.71 7.3 9.14 5.38 12 5.38z"
              />
            </svg>
          </span>
          <span class="leading-tight">
            <span class="flex items-center gap-1.5">
              <span class="font-heading text-base font-semibold text-primary sm:text-lg">
                {rating.toFixed(1)}
              </span>
              <span class="flex" aria-hidden="true">
                {Array.from({ length: 5 }).map((_, i) => (
                  <svg
                    width="13"
                    height="13"
                    viewBox="0 0 24 24"
                    class={i < filledStars ? 'text-accent' : 'text-neutral/20'}
                    fill="currentColor"
                  >
                    <path d="M12 17.27 18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z" />
                  </svg>
                ))}
              </span>
            </span>
            <span class="block font-body text-xs text-neutral/60">
              {reviewCount ? `${reviewCount}+ ` : ''}Google reviews
            </span>
          </span>
        </a>
      )
    }

    <!-- Vertical divider between the two stats -->
    {rating && followers && <span class="h-9 w-px bg-neutral/10" />}

    <!-- Instagram -->
    {
      followers && (
        <a
          href={igUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="group flex items-center gap-2.5 sm:gap-3"
          aria-label={`${compact(followers)} Instagram followers, @${igHandle}`}
        >
          <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-primary/5 text-primary transition group-hover:bg-primary/10">
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              aria-hidden="true"
            >
              <rect x="2" y="2" width="20" height="20" rx="5" />
              <circle cx="12" cy="12" r="4" />
              <line x1="17.5" y1="6.5" x2="17.5" y2="6.5" />
            </svg>
          </span>
          <span class="leading-tight">
            <span class="block font-heading text-base font-semibold text-primary sm:text-lg">
              {compact(followers)}
            </span>
            <span class="block font-body text-xs text-neutral/60 group-hover:text-primary">
              @{igHandle}
            </span>
          </span>
        </a>
      )
    }
  </div>
</section>
