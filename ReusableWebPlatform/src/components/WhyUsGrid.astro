---
interface Highlight {
  icon: string;
  title: string;
  text: string;
}
interface Props {
  highlights: Highlight[];
}
const { highlights } = Astro.props;

const iconPaths: Record<string, string> = {
  shield: 'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z',
  clock: 'M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20Zm0 4v6l4 2',
  map: 'M3 7l6-3 6 3 6-3v13l-6 3-6-3-6 3V7Z',
  heart:
    'M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 1 0-7.78 7.78L12 21.23l8.84-8.84a5.5 5.5 0 0 0 0-7.78Z',
  book: 'M4 19.5A2.5 2.5 0 0 1 6.5 17H20M4 19.5V4.5A2.5 2.5 0 0 1 6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5Z',
  users:
    'M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2M9 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8Zm13 10v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75',
  award: 'M12 15l-3.5 2.1 1-3.9L6 10.5l4-.3L12 6.5l2 3.7 4 .3-3.5 2.7 1 3.9Z',
  briefcase:
    'M20 7H4a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2ZM16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2',
  target:
    'M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20Zm0 4a6 6 0 1 0 0 12 6 6 0 0 0 0-12Zm0 4a2 2 0 1 0 0 4 2 2 0 0 0 0-4Z',
  zap: 'M13 2L3 14h9l-1 8 10-12h-9l1-8Z',
};
---

<section class="bg-surface">
  <div class="mx-auto max-w-6xl px-5 py-12 sm:px-6 lg:py-16">
    <p class="font-body text-sm font-medium uppercase tracking-wide text-accent">Why us</p>
    <h2 class="mt-1 font-heading text-2xl text-primary sm:text-3xl">What sets us apart</h2>
    <ul class="mt-8 grid gap-5 sm:grid-cols-2 lg:gap-6">
      {
        highlights.map((h) => (
          <li class="flex gap-4 rounded-theme bg-white p-5 ring-1 ring-neutral/10 sm:p-6">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-primary/10">
              <svg
                class="h-5 w-5 text-primary"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d={iconPaths[h.icon] || iconPaths.heart} />
              </svg>
            </div>
            <div>
              <h3 class="font-body text-sm font-semibold text-neutral">{h.title}</h3>
              <p class="mt-1 font-body text-sm text-neutral/70">{h.text}</p>
            </div>
          </li>
        ))
      }
    </ul>
  </div>
</section>
