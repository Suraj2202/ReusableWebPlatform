---
import { getSiteConfig } from '@/utils/config';

const config = getSiteConfig();
const { contact, social, brand } = config;
const whatsappNumber = social.whatsapp?.replace(/\D/g, '') || '';
---

<section class="section-padding bg-surface" id="contact">
  <div class="container-narrow">
    <!-- Section Header -->
    <div class="section-header" data-animate="fade-up">
      <span class="text-primary font-semibold text-sm uppercase tracking-wider">Contact</span>
      <h2 class="section-title mt-2">{contact.title}</h2>
      <p class="section-subtitle">{contact.subtitle}</p>
    </div>

    <div class="grid md:grid-cols-2 gap-12 lg:gap-16">
      <!-- Contact Info -->
      <div data-animate="fade-right">
        <div class="space-y-6">
          <!-- Phone -->
          {
            contact.phone && (
              <div class="flex items-start gap-4">
                <div class="w-12 h-12 bg-primary/10 rounded-theme flex items-center justify-center shrink-0">
                  <svg
                    class="w-5 h-5 text-primary"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                    />
                  </svg>
                </div>
                <div>
                  <h4 class="font-semibold text-neutral">Phone</h4>
                  <a
                    href={`tel:${contact.phone.replace(/\s/g, '')}`}
                    class="text-neutral/60 hover:text-primary transition-colors"
                  >
                    {contact.phone}
                  </a>
                </div>
              </div>
            )
          }

          <!-- Email -->
          {
            contact.email && (
              <div class="flex items-start gap-4">
                <div class="w-12 h-12 bg-primary/10 rounded-theme flex items-center justify-center shrink-0">
                  <svg
                    class="w-5 h-5 text-primary"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                    />
                  </svg>
                </div>
                <div>
                  <h4 class="font-semibold text-neutral">Email</h4>
                  <a
                    href={`mailto:${contact.email}`}
                    class="text-neutral/60 hover:text-primary transition-colors"
                  >
                    {contact.email}
                  </a>
                </div>
              </div>
            )
          }

          <!-- Address -->
          {
            contact.address && (
              <div class="flex items-start gap-4">
                <div class="w-12 h-12 bg-primary/10 rounded-theme flex items-center justify-center shrink-0">
                  <svg
                    class="w-5 h-5 text-primary"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                    />
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"
                    />
                  </svg>
                </div>
                <div>
                  <h4 class="font-semibold text-neutral">Address</h4>
                  <p class="text-neutral/60">{contact.address}</p>
                </div>
              </div>
            )
          }

          <!-- Working Hours -->
          {
            contact.workingHours && (
              <div class="flex items-start gap-4">
                <div class="w-12 h-12 bg-primary/10 rounded-theme flex items-center justify-center shrink-0">
                  <svg
                    class="w-5 h-5 text-primary"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
                    />
                  </svg>
                </div>
                <div>
                  <h4 class="font-semibold text-neutral">Working Hours</h4>
                  <p class="text-neutral/60">{contact.workingHours}</p>
                </div>
              </div>
            )
          }
        </div>
      </div>

      <!-- Contact Form -->
      <div data-animate="fade-left">
        <form class="bg-white rounded-theme p-8 shadow-sm space-y-5" id="contact-form">
          {
            contact.formFields?.map((field) => (
              <div>
                <label for={field.name} class="block text-sm font-medium text-neutral mb-1.5">
                  {field.label}
                  {field.required && <span class="text-red-500">*</span>}
                </label>
                {field.type === 'textarea' ? (
                  <textarea
                    id={field.name}
                    name={field.name}
                    required={field.required}
                    rows={4}
                    class="w-full px-4 py-3 border border-neutral/20 rounded-theme
                         focus:border-primary focus:ring-2 focus:ring-primary/20 
                         outline-none transition-all duration-200 resize-none"
                    placeholder={`Enter your ${field.label.toLowerCase()}`}
                  />
                ) : (
                  <input
                    type={field.type}
                    id={field.name}
                    name={field.name}
                    required={field.required}
                    class="w-full px-4 py-3 border border-neutral/20 rounded-theme
                         focus:border-primary focus:ring-2 focus:ring-primary/20 
                         outline-none transition-all duration-200"
                    placeholder={`Enter your ${field.label.toLowerCase()}`}
                  />
                )}
              </div>
            ))
          }
          <button type="submit" class="btn-primary w-full">
            Send via WhatsApp
            <svg class="w-5 h-5 ml-2" fill="currentColor" viewBox="0 0 24 24">
              <path
                d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
              ></path>
            </svg>
          </button>
          <p class="text-xs text-neutral/40 text-center">
            Opens WhatsApp with your message pre-filled
          </p>
        </form>

        <!-- Form Success Message -->
        <div
          class="hidden bg-green-50 border border-green-200 rounded-theme p-6 text-center mt-4"
          id="form-success"
        >
          <svg
            class="w-12 h-12 text-green-500 mx-auto mb-3"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          <h4 class="font-semibold text-green-800">Message Sent!</h4>
          <p class="text-green-600 text-sm mt-1">We'll get back to you within 24 hours.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<script define:vars={{ whatsappNumber, brandName: brand.name }}>
  const form = document.getElementById('contact-form');

  form?.addEventListener('submit', (e) => {
    e.preventDefault();

    // Gather all form field values
    const formData = new FormData(form);
    let waMessage = `Hi ${brandName}! I'm interested in your services.\n\n`;
    for (const [key, value] of formData.entries()) {
      if (value) {
        const label = key.charAt(0).toUpperCase() + key.slice(1);
        waMessage += `*${label}:* ${value}\n`;
      }
    }

    const waUrl = `https://wa.me/${whatsappNumber}?text=${encodeURIComponent(waMessage)}`;
    window.open(waUrl, '_blank', 'noopener,noreferrer');
  });
</script>
