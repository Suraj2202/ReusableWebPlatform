---
import { getSiteConfig } from '@/utils/config';

const config = getSiteConfig();
const { contact } = config;
---

<section class="section-padding bg-surface" id="contact">
  <div class="container-narrow">
    <!-- Section Header -->
    <div class="section-header">
      <span class="text-primary font-semibold text-sm uppercase tracking-wider">Contact</span>
      <h2 class="section-title mt-2">{contact.title}</h2>
      <p class="section-subtitle">{contact.subtitle}</p>
    </div>

    <div class="grid md:grid-cols-2 gap-12 lg:gap-16">
      <!-- Contact Info -->
      <div>
        <div class="space-y-6">
          <!-- Phone -->
          {
            contact.phone && (
              <div class="flex items-start gap-4">
                <div class="w-12 h-12 bg-primary/10 rounded-theme flex items-center justify-center shrink-0">
                  <svg
                    class="w-5 h-5 text-primary"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                    />
                  </svg>
                </div>
                <div>
                  <h4 class="font-semibold text-neutral">Phone</h4>
                  <a
                    href={`tel:${contact.phone.replace(/\s/g, '')}`}
                    class="text-neutral/60 hover:text-primary transition-colors"
                  >
                    {contact.phone}
                  </a>
                </div>
              </div>
            )
          }

          <!-- Email -->
          {
            contact.email && (
              <div class="flex items-start gap-4">
                <div class="w-12 h-12 bg-primary/10 rounded-theme flex items-center justify-center shrink-0">
                  <svg
                    class="w-5 h-5 text-primary"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                    />
                  </svg>
                </div>
                <div>
                  <h4 class="font-semibold text-neutral">Email</h4>
                  <a
                    href={`mailto:${contact.email}`}
                    class="text-neutral/60 hover:text-primary transition-colors"
                  >
                    {contact.email}
                  </a>
                </div>
              </div>
            )
          }

          <!-- Address -->
          {
            contact.address && (
              <div class="flex items-start gap-4">
                <div class="w-12 h-12 bg-primary/10 rounded-theme flex items-center justify-center shrink-0">
                  <svg
                    class="w-5 h-5 text-primary"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                    />
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"
                    />
                  </svg>
                </div>
                <div>
                  <h4 class="font-semibold text-neutral">Address</h4>
                  <p class="text-neutral/60">{contact.address}</p>
                </div>
              </div>
            )
          }

          <!-- Working Hours -->
          {
            contact.workingHours && (
              <div class="flex items-start gap-4">
                <div class="w-12 h-12 bg-primary/10 rounded-theme flex items-center justify-center shrink-0">
                  <svg
                    class="w-5 h-5 text-primary"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
                    />
                  </svg>
                </div>
                <div>
                  <h4 class="font-semibold text-neutral">Working Hours</h4>
                  <p class="text-neutral/60">{contact.workingHours}</p>
                </div>
              </div>
            )
          }
        </div>
      </div>

      <!-- Contact Form -->
      <div>
        <form class="bg-white rounded-theme p-8 shadow-sm space-y-5" id="contact-form">
          {
            contact.formFields?.map((field) => (
              <div>
                <label for={field.name} class="block text-sm font-medium text-neutral mb-1.5">
                  {field.label}
                  {field.required && <span class="text-red-500">*</span>}
                </label>
                {field.type === 'textarea' ? (
                  <textarea
                    id={field.name}
                    name={field.name}
                    required={field.required}
                    rows={4}
                    class="w-full px-4 py-3 border border-neutral/20 rounded-theme
                         focus:border-primary focus:ring-2 focus:ring-primary/20 
                         outline-none transition-all duration-200 resize-none"
                    placeholder={`Enter your ${field.label.toLowerCase()}`}
                  />
                ) : (
                  <input
                    type={field.type}
                    id={field.name}
                    name={field.name}
                    required={field.required}
                    class="w-full px-4 py-3 border border-neutral/20 rounded-theme
                         focus:border-primary focus:ring-2 focus:ring-primary/20 
                         outline-none transition-all duration-200"
                    placeholder={`Enter your ${field.label.toLowerCase()}`}
                  />
                )}
              </div>
            ))
          }
          <button type="submit" class="btn-primary w-full">
            Send Message
            <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
            </svg>
          </button>
        </form>

        <!-- Form Success Message -->
        <div
          class="hidden bg-green-50 border border-green-200 rounded-theme p-6 text-center mt-4"
          id="form-success"
        >
          <svg
            class="w-12 h-12 text-green-500 mx-auto mb-3"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          <h4 class="font-semibold text-green-800">Message Sent!</h4>
          <p class="text-green-600 text-sm mt-1">We'll get back to you within 24 hours.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const success = document.getElementById('form-success');

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    // In production, integrate with Formspree, Cloudflare Workers, or similar
    form.classList.add('hidden');
    success?.classList.remove('hidden');
  });
</script>
