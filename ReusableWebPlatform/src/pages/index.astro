---
import BaseLayout from '@/layouts/BaseLayout.astro';
import VideoBanner from '@/components/VideoBanner.astro';
import CompanyOverview from '@/components/CompanyOverview.astro';
import SocialProofStrip from '@/components/SocialProofStrip.astro';
import StoryCircleRow from '@/components/StoryCircleRow.astro';
import AllToursCarousel from '@/components/AllToursCarousel.astro';
import CategoryBlocks from '@/components/CategoryBlocks.astro';
import { siteConfig, whatsappHref } from '@/utils/whatsapp';

const { name, tagline, description } = siteConfig.site;

const waHref = whatsappHref(`Hi ${name}, I'd like help planning a trip.`);
---

<BaseLayout title={name} description={description}>
  <VideoBanner
    poster="/assets/banner/home-poster.jpg"
    videoSrc="/assets/video/home-banner.mp4"
    headline={name}
    subtext={tagline}
    ctaText="Plan your trip on WhatsApp"
    ctaHref={waHref}
  />

  <SocialProofStrip />
  <CompanyOverview />

  <StoryCircleRow />

  <AllToursCarousel />

  <CategoryBlocks />
</BaseLayout>
