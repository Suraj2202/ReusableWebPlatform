---
import PageLayout from '@/layouts/PageLayout.astro';
import Gallery from '@/components/Gallery.astro';
import { getSiteConfig } from '@/utils/config';

const config = getSiteConfig();
const { gallery } = config;
---

<PageLayout title="Gallery" description={`${gallery.title} — ${gallery.subtitle}`}>
  <!-- Page Hero -->
  <section class="bg-primary text-white section-padding">
    <div class="container-narrow text-center">
      <span class="text-accent font-semibold text-sm uppercase tracking-wider">Portfolio</span>
      <h1 class="text-4xl md:text-5xl font-bold mt-2 mb-6">{gallery.title}</h1>
      <p class="text-white/80 text-lg max-w-2xl mx-auto">
        {gallery.subtitle}
      </p>
    </div>
  </section>

  <!-- Gallery Component (reused from home) -->
  <Gallery />

  <!-- CTA -->
  <section class="section-padding bg-primary text-white text-center">
    <div class="container-narrow">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">Want to be part of our gallery?</h2>
      <p class="text-white/80 text-lg mb-8 max-w-xl mx-auto">
        Book your experience and create memories worth sharing.
      </p>
      <a href="/contact" class="btn-accent text-lg px-8 py-4">
        Book Now
        <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
        </svg>
      </a>
    </div>
  </section>
</PageLayout>
