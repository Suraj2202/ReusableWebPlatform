---
import PageLayout from '@/layouts/PageLayout.astro';
import { getSiteConfig } from '@/utils/config';

const config = getSiteConfig();
const { services } = config;

/** Extract anchor id: "/tours#beach" → "beach", or fallback to slugified title */
function getServiceSlug(service: { href?: string; title: string }): string {
  if (service.href?.includes('#')) {
    return service.href.split('#')[1];
  }
  return service.title.toLowerCase().replace(/\s+/g, '-');
}

const iconMap: Record<string, string> = {
  sun: 'M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z',
  mountain: 'M4 20L8 10l4 6 4-8 4 12H4z',
  landmark: 'M3 21h18M3 10h18M5 6l7-3 7 3M4 10v11M20 10v11M8 14v3M12 14v3M16 14v3',
  binoculars:
    'M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9',
  building:
    'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4',
  ship: 'M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z',
  star: 'M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z',
  default: 'M13 10V3L4 14h7v7l9-11h-7z',
};
---

<PageLayout
  title={services.title}
  description={`Explore our ${services.items.length} services — ${services.subtitle}`}
>
  <!-- Page Hero -->
  <section class="bg-primary text-white section-padding">
    <div class="container-narrow text-center">
      <span class="text-accent font-semibold text-sm uppercase tracking-wider">What We Offer</span>
      <h1 class="text-4xl md:text-5xl font-bold mt-2 mb-6">
        {services.title}
      </h1>
      <p class="text-white/80 text-lg max-w-2xl mx-auto">
        {services.subtitle}
      </p>
    </div>
  </section>

  <!-- Services Grid -->
  <section class="section-padding bg-white">
    <div class="container-narrow">
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {
          services.items.map((service) => (
            <a href={`#${getServiceSlug(service)}`} class="card group cursor-pointer">
              {service.image && (
                <div class="aspect-[4/3] overflow-hidden">
                  <img
                    src={service.image}
                    alt={service.title}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                    loading="lazy"
                  />
                </div>
              )}
              <div class="p-6">
                <div class="w-12 h-12 bg-primary/10 rounded-theme flex items-center justify-center mb-4 group-hover:bg-primary/20 transition-colors">
                  <svg
                    class="w-6 h-6 text-primary"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="1.5"
                      d={iconMap[service.icon] || iconMap.default}
                    />
                  </svg>
                </div>
                <h3 class="text-xl font-bold text-neutral mb-2 group-hover:text-primary transition-colors">
                  {service.title}
                </h3>
                <p class="text-neutral/60 leading-relaxed text-sm">{service.description}</p>
                <span class="inline-flex items-center text-primary font-medium text-sm mt-4">
                  View Details
                  <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M19 14l-7 7m0 0l-7-7m7 7V3"
                    />
                  </svg>
                </span>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Service Details -->
  {
    services.items.map((service, index) => (
      <section
        class={`section-padding ${index % 2 === 0 ? 'bg-surface' : 'bg-white'}`}
        id={getServiceSlug(service)}
      >
        <div class="container-narrow">
          <div
            class={`grid md:grid-cols-2 gap-12 lg:gap-16 items-center ${index % 2 !== 0 ? 'md:[direction:rtl] md:[&>*]:[direction:ltr]' : ''}`}
          >
            {service.image && (
              <div>
                <img
                  src={service.image}
                  alt={service.title}
                  class="rounded-theme shadow-lg w-full object-cover aspect-[4/3]"
                  loading="lazy"
                />
              </div>
            )}
            <div>
              <div class="flex items-center gap-3 mb-4">
                <div class="w-10 h-10 bg-primary/10 rounded-theme flex items-center justify-center">
                  <svg
                    class="w-5 h-5 text-primary"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="1.5"
                      d={iconMap[service.icon] || iconMap.default}
                    />
                  </svg>
                </div>
                <span class="text-primary font-semibold text-sm uppercase tracking-wider">
                  {service.title}
                </span>
              </div>
              <h2 class="text-3xl font-bold text-neutral mb-4">{service.title}</h2>
              <p class="text-neutral/70 leading-relaxed text-lg mb-6">{service.description}</p>
              <ul class="space-y-3 mb-8">
                <li class="flex items-center gap-3 text-neutral/70">
                  <svg class="w-5 h-5 text-accent shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path
                      fill-rule="evenodd"
                      d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                      clip-rule="evenodd"
                    />
                  </svg>
                  Professional guides & support
                </li>
                <li class="flex items-center gap-3 text-neutral/70">
                  <svg class="w-5 h-5 text-accent shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path
                      fill-rule="evenodd"
                      d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                      clip-rule="evenodd"
                    />
                  </svg>
                  Customizable packages
                </li>
                <li class="flex items-center gap-3 text-neutral/70">
                  <svg class="w-5 h-5 text-accent shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path
                      fill-rule="evenodd"
                      d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                      clip-rule="evenodd"
                    />
                  </svg>
                  Best price guarantee
                </li>
              </ul>
              <a href="/contact" class="btn-primary">
                Enquire Now
                <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M14 5l7 7m0 0l-7 7m7-7H3"
                  />
                </svg>
              </a>
            </div>
          </div>
        </div>
      </section>
    ))
  }

  <!-- CTA -->
  <section class="section-padding bg-primary text-white text-center">
    <div class="container-narrow">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">Can't find what you're looking for?</h2>
      <p class="text-white/80 text-lg mb-8 max-w-xl mx-auto">
        We create custom packages tailored to your needs. Tell us what you want and we'll make it
        happen.
      </p>
      <a href="/contact" class="btn-accent text-lg px-8 py-4">
        Get a Custom Quote
        <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
        </svg>
      </a>
    </div>
  </section>
</PageLayout>
