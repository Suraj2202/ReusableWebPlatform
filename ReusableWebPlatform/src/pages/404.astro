---
import PageLayout from '@/layouts/PageLayout.astro';
---

<PageLayout title="Page Not Found" description="The page you're looking for doesn't exist.">
  <section class="min-h-[60vh] flex items-center justify-center section-padding">
    <div class="text-center">
      <h1 class="text-8xl md:text-9xl font-bold text-primary/20 mb-4">404</h1>
      <h2 class="text-2xl md:text-3xl font-bold text-neutral mb-4">Page Not Found</h2>
      <p class="text-neutral/60 mb-8 max-w-md mx-auto">
        The page you're looking for doesn't exist or has been moved.
      </p>
      <a href="/" class="btn-primary">
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
        </svg>
        Back to Home
      </a>
    </div>
  </section>
</PageLayout>
