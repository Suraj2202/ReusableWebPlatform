---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { siteConfig } from '@/utils/whatsapp';
---

<BaseLayout
  title={`Page Not Found — ${siteConfig.site.name}`}
  description="The page you're looking for doesn't exist."
>
  <section class="flex min-h-[60vh] items-center justify-center bg-surface px-5">
    <div class="text-center">
      <p class="font-heading text-8xl font-bold text-accent sm:text-9xl">404</p>
      <h1 class="mt-4 font-heading text-2xl text-primary sm:text-3xl">Page not found</h1>
      <p class="mt-2 font-body text-neutral/60">
        The trail you're looking for doesn't exist — or has moved.
      </p>
      <a
        href="/"
        class="mt-8 inline-block rounded-lg bg-primary px-6 py-3 font-body text-sm font-medium text-white transition hover:bg-secondary"
      >
        Back to Home
      </a>
    </div>
  </section>
</BaseLayout>
