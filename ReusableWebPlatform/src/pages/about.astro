---
import PageLayout from '@/layouts/PageLayout.astro';
import { getSiteConfig } from '@/utils/config';

const config = getSiteConfig();
const { about, brand } = config;
---

<PageLayout title="About Us" description={about.description}>
  <!-- Page Hero -->
  <section class="bg-primary text-white section-padding">
    <div class="container-narrow text-center">
      <span class="text-accent font-semibold text-sm uppercase tracking-wider">About Us</span>
      <h1 class="text-4xl md:text-5xl font-bold mt-2 mb-6">{about.title}</h1>
      <p class="text-white/80 text-lg max-w-2xl mx-auto">{brand.tagline}</p>
    </div>
  </section>

  <!-- About Content -->
  <section class="section-padding bg-white">
    <div class="container-narrow">
      <div class="grid md:grid-cols-2 gap-12 lg:gap-16 items-center">
        {
          about.image && (
            <div class="relative">
              <img
                src={about.image}
                alt={about.title}
                class="rounded-theme shadow-lg w-full object-cover aspect-[4/3]"
                loading="lazy"
              />
              <div class="absolute -bottom-4 -right-4 w-full h-full border-2 border-primary/20 rounded-theme -z-10" />
            </div>
          )
        }
        <div>
          <h2 class="text-3xl font-bold text-neutral mb-6">Our Story</h2>
          <p class="text-neutral/70 leading-relaxed text-lg mb-6">
            {about.description}
          </p>
          <p class="text-neutral/60 leading-relaxed">
            Founded in {brand.foundedYear}, {brand.name} has grown from a small passion project into a
            trusted name in the industry. Our commitment to excellence and personalized service sets us
            apart.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats -->
  {
    about.stats && about.stats.length > 0 && (
      <section class="section-padding bg-surface">
        <div class="container-narrow">
          <div class="text-center mb-12">
            <h2 class="section-title">By the Numbers</h2>
            <p class="section-subtitle">Our journey in milestones</p>
          </div>
          <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
            {about.stats.map((stat) => (
              <div class="text-center p-6 bg-white rounded-theme shadow-sm">
                <div class="text-4xl md:text-5xl font-bold text-primary mb-2">{stat.value}</div>
                <div class="text-neutral/60 font-medium">{stat.label}</div>
              </div>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <!-- Values -->
  <section class="section-padding bg-white">
    <div class="container-narrow">
      <div class="text-center mb-12">
        <h2 class="section-title">What Drives Us</h2>
        <p class="section-subtitle">The principles behind everything we do</p>
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="text-center p-8">
          <div
            class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4"
          >
            <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="1.5"
                d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"
              ></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-neutral mb-3">Passion</h3>
          <p class="text-neutral/60 leading-relaxed">
            We're driven by a genuine love for what we do. Every project is a chance to create
            something meaningful.
          </p>
        </div>
        <div class="text-center p-8">
          <div
            class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4"
          >
            <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="1.5"
                d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
              ></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-neutral mb-3">Trust</h3>
          <p class="text-neutral/60 leading-relaxed">
            Transparency and reliability are at the core of every interaction. Your trust is
            something we never take for granted.
          </p>
        </div>
        <div class="text-center p-8">
          <div
            class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4"
          >
            <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="1.5"
                d="M13 10V3L4 14h7v7l9-11h-7z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-neutral mb-3">Excellence</h3>
          <p class="text-neutral/60 leading-relaxed">
            We aim for the highest quality in every detail. Good enough is never enough when
            perfection is within reach.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-padding bg-primary text-white text-center">
    <div class="container-narrow">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">Ready to Get Started?</h2>
      <p class="text-white/80 text-lg mb-8 max-w-xl mx-auto">
        We'd love to hear from you. Let's discuss how we can help.
      </p>
      <a href="/contact" class="btn-accent text-lg px-8 py-4">
        Contact Us
        <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
        </svg>
      </a>
    </div>
  </section>
</PageLayout>
