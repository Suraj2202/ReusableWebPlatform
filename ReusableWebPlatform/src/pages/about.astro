---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ProgramPageHero from '@/components/ProgramPageHero.astro';
import WhyUsGrid from '@/components/WhyUsGrid.astro';
import ReviewsCarousel from '@/components/ReviewsCarousel.astro';
import { siteConfig } from '@/utils/whatsapp';

const { title, tagline, image, story, values } = siteConfig.about;
const { stats } = siteConfig.overview;
---

<BaseLayout title={`${title} — ${siteConfig.site.name}`} description={tagline}>
  <ProgramPageHero title={title} tagline={tagline} image={image} />

  <!-- Our Story -->
  <section class="bg-white">
    <div class="mx-auto max-w-6xl px-5 py-12 sm:px-6 lg:py-16">
      <div class="mx-auto max-w-3xl">
        <p class="font-body text-sm font-medium uppercase tracking-wide text-accent">Our story</p>
        <h2 class="mt-1 font-heading text-2xl text-primary sm:text-3xl">How Hidden Naqsha began</h2>
        <div class="mt-6 space-y-4">
          {
            story.map((para: string) => (
              <p class="font-body leading-relaxed text-neutral/70">{para}</p>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- Stats Strip -->
  <section class="bg-surface">
    <div class="mx-auto max-w-4xl px-5 py-10 sm:px-6">
      <div class="grid grid-cols-3 gap-6 text-center">
        {
          stats.map((stat: { value: string; label: string }) => (
            <div>
              <p class="font-heading text-3xl text-accent sm:text-4xl">{stat.value}</p>
              <p class="mt-1 font-body text-sm text-neutral/60">{stat.label}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <WhyUsGrid highlights={values} />
  <ReviewsCarousel />
</BaseLayout>
