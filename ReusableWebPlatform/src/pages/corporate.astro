---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ProgramPageHero from '@/components/ProgramPageHero.astro';
import WhyUsGrid from '@/components/WhyUsGrid.astro';
import EnquiryForm from '@/components/EnquiryForm.astro';
import ReviewsCarousel from '@/components/ReviewsCarousel.astro';
import { siteConfig } from '@/utils/whatsapp';

const program = siteConfig.programs.corporate;
const { title, tagline, image, narrative, highlights } = program;
---

<BaseLayout title={`${title} — ${siteConfig.site.name}`} description={tagline}>
  <ProgramPageHero title={title} tagline={tagline} image={image} />

  <!-- What We Do -->
  <section class="bg-white">
    <div class="mx-auto max-w-6xl px-5 py-12 sm:px-6 lg:py-16">
      <div class="mx-auto max-w-3xl">
        <p class="font-body text-sm font-medium uppercase tracking-wide text-accent">What we do</p>
        <h2 class="mt-1 font-heading text-2xl text-primary sm:text-3xl">
          Team retreats, done right
        </h2>
        <div class="mt-6 space-y-4">
          {
            narrative.map((para: string) => (
              <p class="font-body leading-relaxed text-neutral/70">{para}</p>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <WhyUsGrid highlights={highlights} />
  <EnquiryForm tripType="Corporate" whatsappNumber={siteConfig.contact.whatsapp} />
  <ReviewsCarousel />
</BaseLayout>
