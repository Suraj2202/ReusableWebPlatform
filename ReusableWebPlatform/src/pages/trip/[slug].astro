---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import StickyTabNav from '@/components/StickyTabNav.astro';
import ItineraryAccordion from '@/components/ItineraryAccordion.astro';
import ReviewsCarousel from '@/components/ReviewsCarousel.astro';
import { getAllTrips, formatPrice, formatDuration } from '@/utils/trips';
import { siteConfig, whatsappHref } from '@/utils/whatsapp';

export async function getStaticPaths() {
  const trips = await getAllTrips();
  const categories = await getCollection('categories');
  const categoryTitle = Object.fromEntries(categories.map((c) => [c.data.slug, c.data.title]));
  return trips.map((trip) => ({
    params: { slug: trip.data.slug },
    props: { trip, categoryTitle: categoryTitle[trip.data.category] ?? trip.data.category },
  }));
}

const { trip, categoryTitle } = Astro.props;
const {
  title,
  category,
  cover,
  gallery,
  durationNights,
  durationDays,
  pickup,
  drop,
  priceFrom,
  overview,
  highlights,
  itinerary,
  inclusions,
  exclusions,
  otherInfo,
} = trip.data;

const { name } = siteConfig.site;
const waHref = whatsappHref(
  `Hi ${name}, I'm interested in the "${title}" trip. Could you share details?`,
);

const tabs = [
  { id: 'overview', label: 'Overview' },
  { id: 'itinerary', label: 'Itinerary' },
  { id: 'inclusions', label: 'Inclusions' },
  { id: 'exclusions', label: 'Exclusions' },
  { id: 'other-info', label: 'Other Info' },
];

const mustCarry = otherInfo?.mustCarry ?? [];
---

<BaseLayout title={`${title} — ${name}`} description={overview}>
  <!-- Hero -->
  <section class="relative">
    <div class="relative h-72 overflow-hidden sm:h-96">
      <img
        src={`/assets/${cover}`}
        alt={title}
        width="1280"
        height="720"
        class="h-full w-full object-cover"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-neutral/80 via-neutral/30 to-transparent">
      </div>
      <div class="absolute inset-x-0 bottom-0">
        <div class="mx-auto max-w-6xl px-6 pb-8">
          <nav class="mb-3 font-body text-sm text-surface/80" aria-label="Breadcrumb">
            <a href="/" class="underline-offset-4 hover:underline">Home</a>
            <span aria-hidden="true" class="px-1.5">/</span>
            <a href={`/explore/${category}`} class="underline-offset-4 hover:underline"
              >{categoryTitle}</a
            >
            <span aria-hidden="true" class="px-1.5">/</span>
            <span class="text-surface">{title}</span>
          </nav>
          <h1 class="font-heading text-3xl text-surface sm:text-4xl">{title}</h1>
          <div
            class="mt-3 flex flex-wrap items-center gap-x-5 gap-y-2 font-body text-sm text-surface/90"
          >
            <span class="inline-flex items-center gap-1.5">
              <svg
                class="h-4 w-4 text-accent"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                aria-hidden="true"
              >
                <circle cx="12" cy="12" r="9"></circle>
                <path d="M12 7v5l3 2" stroke-linecap="round" stroke-linejoin="round"></path>
              </svg>
              {formatDuration(durationNights, durationDays)}
            </span>
            <span class="inline-flex items-center gap-1.5">
              <svg
                class="h-4 w-4 text-accent"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                aria-hidden="true"
              >
                <path
                  d="M12 21s-7-5.2-7-11a7 7 0 1 1 14 0c0 5.8-7 11-7 11Z"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path>
                <circle cx="12" cy="10" r="2.5"></circle>
              </svg>
              {pickup} → {drop}
            </span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <StickyTabNav tabs={tabs} />

  <div class="mx-auto max-w-6xl px-6 pb-28 pt-10">
    <!-- Overview + highlights -->
    <section id="overview" class="scroll-mt-32" aria-labelledby="overview-heading">
      <h2 id="overview-heading" class="font-heading text-2xl text-primary">Overview</h2>
      <p class="mt-3 font-body leading-relaxed text-neutral/70">{overview}</p>
      {
        highlights.length > 0 && (
          <ul class="mt-5 flex flex-wrap gap-2">
            {highlights.map((highlight) => (
              <li class="rounded-full bg-primary/10 px-3 py-1.5 font-body text-sm text-primary">
                {highlight}
              </li>
            ))}
          </ul>
        )
      }
    </section>

    <!-- Itinerary -->
    {
      itinerary.length > 0 && (
        <section id="itinerary" class="mt-12 scroll-mt-32" aria-labelledby="itinerary-heading">
          <h2 id="itinerary-heading" class="font-heading text-2xl text-primary">
            Itinerary
          </h2>
          <p class="mt-2 font-body text-sm text-neutral/60">
            {durationDays} days · {durationNights} nights
          </p>
          <div class="mt-5">
            <ItineraryAccordion itinerary={itinerary} />
          </div>
        </section>
      )
    }

    <!-- Inclusions / Exclusions -->
    <div class="mt-12 grid gap-8 lg:grid-cols-2">
      {
        inclusions.length > 0 && (
          <section id="inclusions" class="scroll-mt-32" aria-labelledby="inclusions-heading">
            <h2 id="inclusions-heading" class="font-heading text-2xl text-primary">
              Inclusions
            </h2>
            <ul class="mt-4 space-y-2.5">
              {inclusions.map((item) => (
                <li class="flex gap-3 font-body text-sm text-neutral/70">
                  <svg
                    class="mt-0.5 h-5 w-5 shrink-0 text-primary"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    aria-hidden="true"
                  >
                    <circle cx="12" cy="12" r="9" />
                    <path
                      d="M8 12.5l2.5 2.5L16 9.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    />
                  </svg>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </section>
        )
      }
      {
        exclusions.length > 0 && (
          <section id="exclusions" class="scroll-mt-32" aria-labelledby="exclusions-heading">
            <h2 id="exclusions-heading" class="font-heading text-2xl text-primary">
              Exclusions
            </h2>
            <ul class="mt-4 space-y-2.5">
              {exclusions.map((item) => (
                <li class="flex gap-3 font-body text-sm text-neutral/70">
                  <svg
                    class="mt-0.5 h-5 w-5 shrink-0 text-neutral/40"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    aria-hidden="true"
                  >
                    <circle cx="12" cy="12" r="9" />
                    <path d="M9 9l6 6M15 9l-6 6" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </section>
        )
      }
    </div>

    <!-- Other info -->
    {
      mustCarry.length > 0 && (
        <section id="other-info" class="mt-12 scroll-mt-32" aria-labelledby="other-info-heading">
          <h2 id="other-info-heading" class="font-heading text-2xl text-primary">
            Other Info
          </h2>
          <div class="mt-4 rounded-theme border border-neutral/10 bg-white p-5">
            <h3 class="font-body text-sm font-semibold uppercase tracking-wide text-accent">
              Must carry
            </h3>
            <ul class="mt-3 grid gap-2.5 sm:grid-cols-2">
              {mustCarry.map((item) => (
                <li class="flex gap-2.5 font-body text-sm text-neutral/70">
                  <span
                    aria-hidden="true"
                    class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-accent"
                  />
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        </section>
      )
    }

    <!-- Gallery -->
    {
      gallery.length > 0 && (
        <section id="gallery" class="mt-12 scroll-mt-32" aria-labelledby="gallery-heading">
          <h2 id="gallery-heading" class="font-heading text-2xl text-primary">
            Journey in frames
          </h2>
          <ul class="mt-5 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {gallery.map((image, index) => (
              <li class="overflow-hidden rounded-theme">
                <img
                  src={`/assets/${image}`}
                  alt={`${title} — photo ${index + 1}`}
                  width="640"
                  height="480"
                  loading="lazy"
                  decoding="async"
                  class="aspect-[4/3] h-full w-full object-cover transition-transform duration-300 hover:scale-105"
                />
              </li>
            ))}
          </ul>
        </section>
      )
    }
  </div>

  <!-- Reviews (global Google reviews) -->
  <ReviewsCarousel />

  <!-- Sticky enquire bar -->
  <div
    class="fixed inset-x-0 bottom-0 z-40 border-t border-neutral/10 bg-surface/95 backdrop-blur"
    style="padding-bottom: env(safe-area-inset-bottom);"
  >
    <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-6 py-3">
      <div class="min-w-0">
        <p class="font-body text-xs text-neutral/50">Starting from</p>
        <p class="font-heading text-lg font-semibold text-neutral">
          {formatPrice(priceFrom)}
          <span class="text-xs font-normal text-neutral/50">/ person</span>
        </p>
      </div>
      <a
        href={waHref}
        target="_blank"
        rel="noopener"
        class="inline-flex shrink-0 items-center gap-2 rounded-full bg-primary px-5 py-2.5 font-body text-sm font-semibold text-white shadow-sm transition hover:bg-secondary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2"
      >
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path
            d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38c1.45.79 3.08 1.21 4.79 1.21h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2Z"
          ></path>
        </svg>
        Enquire on WhatsApp
      </a>
    </div>
  </div>
</BaseLayout>
