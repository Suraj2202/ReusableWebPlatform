---
import { ViewTransitions } from 'astro:transitions';
import '@/styles/fonts.css';
import '@/styles/global.css';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import WhatsAppFloatButton from '@/components/WhatsAppFloatButton.astro';
import BackToTop from '@/components/BackToTop.astro';
import { siteConfig } from '@/utils/whatsapp';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  hideFloatMobile?: boolean;
  showWhatsApp?: boolean;
}

const { name } = siteConfig.site;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const {
  title = name,
  description = siteConfig.site.description,
  ogImage = '/assets/brand/og-image.jpg',
  hideFloatMobile = false,
  showWhatsApp = false,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL.href} />

    <!-- Favicon -->
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site).href} />
    <meta property="og:locale" content="en_IN" />
    <meta property="og:site_name" content={name} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site).href} />

    <!-- Theme -->
    <meta name="theme-color" content="#1B3A2D" />

    <ViewTransitions />
  </head>
  <body class="min-h-screen flex flex-col">
    <Header transition:persist />
    <main class="flex-1" transition:animate="fade">
      <slot />
    </main>
    <Footer transition:persist />
    {showWhatsApp && (
      <div class:list={[{ 'hidden md:block': hideFloatMobile }]} transition:persist>
        <WhatsAppFloatButton />
      </div>
    )}
    <BackToTop transition:persist />
  </body>
</html>
