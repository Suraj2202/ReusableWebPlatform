{
  "name": "reusable-web-platform",
  "type": "module",
  "version": "1.0.0",
  "description": "Reusable static website platform for multi-client deployment",
  "scripts": {
    "dev": "astro dev",
    "prebuild": "node scripts/optimize-images.mjs",
    "build": "astro build",
    "preview": "astro preview",
    "lint": "prettier --check \"src/**/*.{astro,css,ts,js}\"",
    "lint:fix": "prettier --write \"src/**/*.{astro,css,ts,js}\"",
    "check": "astro check",
    "validate": "npm run lint && npm run build",
    "prepare": "husky",
    "astro": "astro"
  },
  "lint-staged": {
    "*.{astro,css,ts,js,json,yaml,yml}": "prettier --write",
    "*.{ts,js}": "prettier --write"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.2.0",
    "@astrojs/tailwind": "^6.0.0",
    "@rollup/plugin-yaml": "^5.0.0",
    "astro": "^5.0.0",
    "js-yaml": "^4.2.0",
    "sharp": "^0.33.0",
    "tailwindcss": "^3.4.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.4.0",
    "prettier-plugin-astro": "^0.14.0",
    "typescript": "^5.7.0"
  }
}
